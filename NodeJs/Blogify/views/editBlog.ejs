<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Blog</title>
</head>
<body>
    <%- include('./partials/nav') %>

    <main>
        <div class="edit-container">
        <div class="header-section">
            <h1>✏️ Edit Blog Post</h1>
            <a href="/blog/<%= blog._id %>" class="breadcrumb-link">← Back to Blog</a>
        </div>

        <form action="/blog/edit/<%= blog._id %>" method="POST" enctype="multipart/form-data">
            
            <!-- Blog Title Section -->
            <div class="form-section">
                <div class="form-section-title">Blog Title</div>
                <div class="form-group">
                    <label for="title">Title *</label>
                    <input 
                        type="text" 
                        id="title"
                        name="title" 
                        value="<%= blog.title %>" 
                        placeholder="Enter your blog title..."
                        required 
                    />
                </div>
            </div>

            <!-- Blog Content Section -->
            <div class="form-section">
                <div class="form-section-title">Blog Content</div>
                <div class="form-group">
                    <label for="body">Content *</label>
                    <textarea 
                        id="body"
                        name="body" 
                        placeholder="Write your blog content here..."
                        required
                    ><%= blog.body %></textarea>
                </div>
            </div>

            <!-- Cover Image Section -->
            <div class="form-section">
                <div class="form-section-title">Cover Image</div>
                
                <div class="current-cover">
                    <label>Current Cover Image:</label>
                    <img src="<%= blog.coverImageURL %>" alt="Current Cover" />
                </div>

                <div class="form-group">
                    <label for="coverImage">Upload New Cover Image (Optional)</label>
                    <input 
                        type="file" 
                        id="coverImage"
                        name="coverImage" 
                        accept="image/*" 
                    />
                    <div class="cover-hint">
                        💡 Leave empty to keep the existing image. Supported formats: JPEG, PNG, WebP, GIF (Max 10MB)
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="button-group">
                <button type="submit" class="btn btn-primary">💾 Save Changes</button>
                <a href="/blog/<%= blog._id %>" class="btn btn-secondary" style="text-decoration: none;">Cancel</a>
            </div>
        </form>
    </div>
    </main>

    <%- include('./partials/footer') %>
    <%- include('./partials/scripts') %>
</body>
</html>